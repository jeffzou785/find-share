# 复制为 .env 并按需修改

# 项目根目录（默认当前目录）
PROJECT_ROOT=.

# DuckDB 路径
DUCKDB_PATH=data/duckdb/find_share.duckdb

# PDF 原始文件目录
ANNUAL_REPORT_PDF_DIR=data/pdfs/annual_reports
RESEARCH_REPORT_DIR=research_reports

# AkShare 重试配置
AKSHARE_MAX_RETRIES=3
AKSHARE_RETRY_BASE_DELAY=1.0

# 数据缓存目录
CACHE_DIR=data/cache

# Tushare 升级时填入（当前不用）
TUSHARE_TOKEN=
